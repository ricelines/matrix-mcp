{
  manifest_version: "0.3.0",

  config_schema: {
    type: "object",
    properties: {
      username: { type: "string" },
      password: { type: "string", secret: true },
      registration_token: {
        type: "string",
        secret: true,
        description: "Optional registration token used by user creation on homeservers that require m.login.registration_token.",
      },
      scopes: {
        type: "string",
        default: "default",
        description: "Comma-separated scope list. Available scopes: client.identity.read, client.status.read, server.read, users.read, users.create, rooms.read, rooms.alias.read, rooms.directory.read, rooms.create, rooms.alias.write, rooms.directory.write, rooms.join, rooms.invite, rooms.leave, room.members.read, room.state.read, timeline.read, messages.send, messages.reply, messages.edit, messages.react, messages.redact. The special value default expands to: client.identity.read, client.status.read, server.read, users.read, rooms.read, room.members.read, room.state.read, timeline.read.",
      },
      listen_addr: { type: "string", default: ":8080" },
    },
    required: ["username", "password"],
    additionalProperties: false,
  },

  slots: {
    matrix: { kind: "http" },
  },

  program: {
    image: "ghcr.io/ricelines/matrix-mcp:v0.1",
    entrypoint: ["/app/matrix-mcp-server"],
    env: {
      MATRIX_HOMESERVER_URL: "${slots.matrix.url}",
      MATRIX_USERNAME: "${config.username}",
      MATRIX_PASSWORD: "${config.password}",
      MATRIX_REGISTRATION_TOKEN: {
        when: "config.registration_token",
        value: "${config.registration_token}",
      },
      MATRIX_MCP_SCOPES: "${config.scopes}",
      MATRIX_MCP_LISTEN_ADDR: "${config.listen_addr}",
    },
    network: {
      endpoints: [
        { name: "mcp", port: 8080, protocol: "http" },
      ],
    },
  },

  provides: {
    mcp: { kind: "mcp", endpoint: "mcp" },
  },

  exports: {
    mcp: "mcp",
  },
}
